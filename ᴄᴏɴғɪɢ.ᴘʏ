#                         бҙ„бҙҸЙҙТ“ЙӘЙўбҙңКҖбҙҖбҙӣЙӘбҙҸЙҙ бҙҚбҙҖЙҙбҙҖЙўбҙҮКҖ
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

import os
import re
from dataclasses import dataclass, field
from typing import Optional, List
from datetime import datetime

@dataclass
class Config:
    """бҙҮЙҙбҙӣбҙҮКҖбҙҳКҖЙӘsбҙҮ бҙ„бҙҸЙҙТ“ЙӘЙўбҙңКҖбҙҖбҙӣЙӘбҙҸЙҙ бҙ„КҹбҙҖss"""
    
    # в”Җв”Җв”Җ КҷбҙҸбҙӣ бҙ„КҖбҙҮбҙ…бҙҮЙҙбҙӣЙӘбҙҖКҹs в”Җв”Җв”Җ
    API_ID: int = int(os.getenv("API_ID", "0"))
    API_HASH: str = os.getenv("API_HASH", "")
    BOT_TOKEN: str = os.getenv("BOT_TOKEN", "")
    BOT_USERNAME: str = os.getenv("BOT_USERNAME", "")
    
    # в”Җв”Җв”Җ бҙ…бҙҖбҙӣбҙҖКҷбҙҖsбҙҮ в”Җв”Җв”Җ
    DATABASE_URL: str = os.getenv("DATABASE_URL", "")
    DB_NAME: str = os.getenv("DB_NAME", "filestore_ultimate")
    
    # в”Җв”Җв”Җ бҙ„КңбҙҖЙҙЙҙбҙҮКҹs (Т“КҹбҙҮxЙӘКҷКҹбҙҮ: sбҙңбҙҳбҙҳбҙҸКҖбҙӣs @username бҙҸКҖ ЙӘбҙ…) в”Җв”Җв”Җ
    FORCE_SUB_CHANNEL: str = os.getenv("FORCE_SUB_CHANNEL", "")
    LOG_CHANNEL: str = os.getenv("LOG_CHANNEL", "")
    DB_CHANNEL: str = os.getenv("DB_CHANNEL", "")  # Т“бҙҸКҖ Т“ЙӘКҹбҙҮ sбҙӣбҙҸКҖбҙҖЙўбҙҮ
    ADMIN_CHANNEL: str = os.getenv("ADMIN_CHANNEL", "")  # Т“бҙҸКҖ бҙҖбҙ…бҙҚЙӘЙҙ бҙҖКҹбҙҮКҖбҙӣs
    
    # в”Җв”Җв”Җ бҙҸбҙЎЙҙбҙҮКҖs в”Җв”Җв”Җ
    OWNER_ID: int = int(os.getenv("OWNER_ID", "0"))
    OWNER_USERNAME: str = os.getenv("OWNER_USERNAME", "its_me_secret")
    ADMIN_IDS: List[int] = field(default_factory=lambda: [
        int(x.strip()) for x in os.getenv("ADMIN_IDS", "").split(",") if x.strip()
    ])
    
    # в”Җв”Җв”Җ бҙҖЙӘ бҙ„бҙҸЙҙТ“ЙӘЙў в”Җв”Җв”Җ
    XAI_API_KEY: str = os.getenv("XAI_API_KEY", "")
    GROK_MODEL: str = os.getenv("GROK_MODEL", "grok-3")
    AI_ENABLED: bool = bool(os.getenv("XAI_API_KEY"))
    
    # в”Җв”Җв”Җ бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ бҙ„бҙҸЙҙТ“ЙӘЙў в”Җв”Җв”Җ
    UPI_ID: str = os.getenv("UPI_ID", "")
    UPI_QR_PATH: str = os.getenv("UPI_QR_PATH", "payment_qr.jpg")
    PAYMENT_AMOUNT: int = int(os.getenv("PAYMENT_AMOUNT", "9"))  # вӮ№9
    PREMIUM_DAYS: int = int(os.getenv("PREMIUM_DAYS", "30"))
    CRYPTO_ENABLED: bool = os.getenv("CRYPTO_ENABLED", "false").lower() == "true"
    
    # в”Җв”Җв”Җ sбҙҮбҙ„бҙңКҖЙӘбҙӣКҸ в”Җв”Җв”Җ
    ANTI_SPAM: bool = True
    RATE_LIMIT: int = int(os.getenv("RATE_LIMIT", "20"))  # бҙҚsЙўs бҙҳбҙҮКҖ бҙҚЙӘЙҙбҙңбҙӣбҙҮ
    SESSION_TIMEOUT: int = 3600  # 1 КңбҙҸбҙңКҖ
    
    # в”Җв”Җв”Җ Т“бҙҮбҙҖбҙӣбҙңКҖбҙҮs в”Җв”Җв”Җ
    MAX_FREE_FILES: int = 100
    MAX_PREMIUM_FILES: int = 100000  # бҙ ЙӘКҖбҙӣбҙңбҙҖКҹКҹКҸ бҙңЙҙКҹЙӘбҙҚЙӘбҙӣбҙҮбҙ…
    MAX_FILE_SIZE_FREE: int = 100 * 1024 * 1024  # 100бҙҚКҷ
    MAX_FILE_SIZE_PREMIUM: int = 2 * 1024 * 1024 * 1024  # 2ЙўКҷ
    BATCH_SIZE: int = 10  # Т“ЙӘКҹбҙҮs бҙҳбҙҮКҖ КҷбҙҖбҙӣбҙ„Кң
    
    # в”Җв”Җв”Җ КҖбҙҮТ“бҙҮКҖКҖбҙҖКҹ в”Җв”Җв”Җ
    REFERRAL_REWARD: int = 5  # Т“КҖбҙҮбҙҮ Т“ЙӘКҹбҙҮs
    REFERRAL_MAX: int = 100  # бҙҚбҙҖx бҙҮбҙҖКҖЙҙбҙҖКҷКҹбҙҮ
    REFERRAL_BONUS_PREMIUM: int = 3  # бҙ…бҙҖКҸs бҙҮxбҙӣКҖбҙҖ Т“бҙҸКҖ КҖбҙҮТ“бҙҮКҖКҖбҙҮКҖ
    
    # в”Җв”Җв”Җ sбҙ„КңбҙҮбҙ…бҙңКҹбҙҮКҖ в”Җв”Җв”Җ
    BACKUP_INTERVAL: int = 86400  # 24 КңбҙҸбҙңКҖs
    CLEANUP_INTERVAL: int = 3600  # 1 КңбҙҸбҙңКҖ
    EXPIRY_CHECK_INTERVAL: int = 1800  # 30 бҙҚЙӘЙҙs
    
    @classmethod
    def validate(cls):
        """бҙ бҙҖКҹЙӘбҙ…бҙҖбҙӣбҙҮ бҙҖКҹКҹ бҙ„бҙҸЙҙТ“ЙӘЙўбҙңКҖбҙҖбҙӣЙӘбҙҸЙҙs"""
        required = ['API_ID', 'API_HASH', 'BOT_TOKEN', 'DATABASE_URL', 'OWNER_ID']
        missing = [f for f in required if not getattr(cls, f)]
        
        if missing:
            raise ValueError(f"бҙҚЙӘssЙӘЙҙЙў КҖбҙҮЗ«бҙңЙӘКҖбҙҮбҙ… бҙ„бҙҸЙҙТ“ЙӘЙўs: {', '.join(missing)}")
        
        # бҙ бҙҖКҹЙӘбҙ…бҙҖбҙӣбҙҮ бҙ„КңбҙҖЙҙЙҙбҙҮКҹ Т“бҙҸКҖбҙҚбҙҖбҙӣs
        if cls.LOG_CHANNEL and not (cls.LOG_CHANNEL.startswith('-100') or cls.LOG_CHANNEL.startswith('@')):
            raise ValueError("КҹбҙҸЙў_бҙ„КңбҙҖЙҙЙҙбҙҮКҹ бҙҚбҙңsбҙӣ sбҙӣбҙҖКҖбҙӣ бҙЎЙӘбҙӣКң -100 (ЙӘбҙ…) бҙҸКҖ @ (бҙңsбҙҮКҖЙҙбҙҖбҙҚбҙҮ)")
    
    @staticmethod
    def get_timestamp() -> str:
        """ЙўбҙҮбҙӣ Т“бҙҸКҖбҙҚбҙҖбҙӣбҙӣбҙҮбҙ… бҙӣЙӘбҙҚбҙҮsбҙӣбҙҖбҙҚбҙҳ"""
        return datetime.now().strftime("%Y-%m-%d %H:%M:%S")

# ЙӘЙҙsбҙӣбҙҖЙҙбҙӣЙӘбҙҖбҙӣбҙҮ
Config = Config()
