# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

import asyncio
import logging
from pyrogram import filters
from pyrogram.types import Message

from config import Config
from database import db
from utils.text import to_small_caps
from utils.formatter import format_size, get_file_icon
from keyboards.file import file_actions_keyboard

logger = logging.getLogger(__name__)

def register(app):
    """КҖбҙҮЙўЙӘsбҙӣбҙҮКҖ Т“ЙӘКҹбҙҮ КңбҙҖЙҙбҙ…КҹбҙҮКҖs"""
    
    @app.on_message(
        (filters.document | filters.video | filters.audio | filters.photo | 
         filters.voice | filters.video_note | filters.animation) & filters.private
    )
    async def file_handler(client, message):
        """КңбҙҖЙҙбҙ…КҹбҙҮ Т“ЙӘКҹбҙҮ бҙңбҙҳКҹбҙҸбҙҖбҙ…s"""
        user_id = message.from_user.id
        
        # бҙ„КңбҙҮбҙ„бҙӢ КҖбҙҖбҙӣбҙҮ КҹЙӘбҙҚЙӘбҙӣs
        if not await check_rate_limit(user_id):
            await message.reply_text(to_small_caps("вҸі бҙӣбҙҸбҙҸ бҙҚбҙҖЙҙКҸ КҖбҙҮЗ«бҙңбҙҮsбҙӣs. бҙҳКҹбҙҮбҙҖsбҙҮ бҙЎбҙҖЙӘбҙӣ."))
            return
        
        # ЙўбҙҮбҙӣ бҙңsбҙҮКҖ бҙ…бҙҖбҙӣбҙҖ
        user = await db.get_user(user_id)
        is_premium = user.get("is_premium", False)
        
        # бҙ„КңбҙҮбҙ„бҙӢ Т“ЙӘКҹбҙҮ КҹЙӘбҙҚЙӘбҙӣs
        if not is_premium and user["file_count"] >= Config.MAX_FREE_FILES:
            await message.reply_text(
                to_small_caps("вҡ пёҸ КҹЙӘбҙҚЙӘбҙӣ КҖбҙҮбҙҖбҙ„КңбҙҮбҙ…! бҙңбҙҳЙўКҖбҙҖбҙ…бҙҮ бҙӣбҙҸ бҙҳКҖбҙҮбҙҚЙӘбҙңбҙҚ."),
                reply_markup=premium_keyboard()
            )
            return
        
        # бҙҮxбҙӣКҖбҙҖбҙ„бҙӣ Т“ЙӘКҹбҙҮ ЙӘЙҙТ“бҙҸ
        file_info = extract_file_info(message)
        
        # бҙ„КңбҙҮбҙ„бҙӢ Т“ЙӘКҹбҙҮ sЙӘбҙўбҙҮ
        max_size = Config.MAX_FILE_SIZE_PREMIUM if is_premium else Config.MAX_FILE_SIZE_FREE
        if file_info["size"] > max_size:
            limit = "2ЙўКҷ" if is_premium else "100бҙҚКҷ"
            await message.reply_text(
                to_small_caps(f"вҡ пёҸ Т“ЙӘКҹбҙҮ бҙӣбҙҸбҙҸ КҷЙӘЙў! КҹЙӘбҙҚЙӘбҙӣ: {limit}")
            )
            return
        
        # sКңбҙҸбҙЎ бҙҳКҖбҙҸЙўКҖбҙҮss
        status_msg = await message.reply_text(to_small_caps("в¬ҶпёҸ бҙңбҙҳКҹбҙҸбҙҖбҙ…ЙӘЙҙЙў..."))
        
        # Т“бҙҸКҖбҙЎбҙҖКҖбҙ… бҙӣбҙҸ sбҙӣбҙҸКҖбҙҖЙўбҙҮ бҙ„КңбҙҖЙҙЙҙбҙҮКҹ ЙӘТ“ бҙ„бҙҸЙҙТ“ЙӘЙўбҙңКҖбҙҮбҙ…
        storage_msg_id = None
        if Config.DB_CHANNEL:
            try:
                forwarded = await message.forward(Config.DB_CHANNEL)
                storage_msg_id = forwarded.id
            except Exception as e:
                logger.error(f"sбҙӣбҙҸКҖбҙҖЙўбҙҮ Т“бҙҸКҖбҙЎбҙҖКҖбҙ… Т“бҙҖЙӘКҹбҙҮбҙ…: {e}")
        
        # sбҙҖбҙ бҙҮ бҙӣбҙҸ бҙ…бҙҖбҙӣбҙҖКҷбҙҖsбҙҮ
        file_data = {
            "file_id": file_info["file_id"],
            "user_id": user_id,
            "file_name": file_info["name"],
            "file_size": file_info["size"],
            "file_type": file_info["type"],
            "mime_type": file_info["mime"],
            "caption": file_info["caption"],
            "storage_msg_id": storage_msg_id,
            "tags": extract_tags(file_info["caption"]),
            "folder": "general"
        }
        
        success = await db.add_file(file_data)
        
        if success:
            share_link = f"https://t.me/{Config.BOT_USERNAME}?start={file_info['file_id']}"
            
            success_text = f"""
вң… Т“ЙӘКҹбҙҮ sбҙӣбҙҸКҖбҙҮбҙ…!

рҹ“Ғ {file_info['name']}
рҹ“Ҡ {format_size(file_info['size'])}
рҹ”— {share_link}
            """
            
            await status_msg.edit_text(
                to_small_caps(success_text),
                reply_markup=file_actions_keyboard(file_info["file_id"], share_link)
            )
            
            # КҹбҙҸЙў бҙҮбҙ бҙҮЙҙбҙӣ
            await db.log_event("file_upload", user_id, {
                "size": file_info["size"],
                "type": file_info["type"]
            })
        else:
            await status_msg.edit_text(to_small_caps("вқҢ Т“бҙҖЙӘКҹбҙҮбҙ… бҙӣбҙҸ sбҙҖбҙ бҙҮ Т“ЙӘКҹбҙҮ."))

def extract_file_info(message):
    """бҙҮxбҙӣКҖбҙҖбҙ„бҙӣ Т“ЙӘКҹбҙҮ ЙӘЙҙТ“бҙҸКҖбҙҚбҙҖбҙӣЙӘбҙҸЙҙ Т“КҖбҙҸбҙҚ бҙҚбҙҮssбҙҖЙўбҙҮ"""
    if message.document:
        return {
            "file_id": message.document.file_id,
            "name": message.document.file_name or "бҙңЙҙЙҙбҙҖбҙҚбҙҮбҙ…",
            "size": message.document.file_size,
            "type": "document",
            "mime": message.document.mime_type,
            "caption": message.caption
        }
    elif message.video:
        return {
            "file_id": message.video.file_id,
            "name": message.video.file_name or f"бҙ ЙӘбҙ…бҙҮбҙҸ_{message.video.file_unique_id}.mp4",
            "size": message.video.file_size,
            "type": "video",
            "mime": message.video.mime_type,
            "caption": message.caption
        }
    # ... (бҙҖбҙ…бҙ… бҙҸбҙӣКңбҙҮКҖ бҙӣКҸбҙҳбҙҮs)

def extract_tags(caption):
    """бҙҮxбҙӣКҖбҙҖбҙ„бҙӣ #бҙӣбҙҖЙўs Т“КҖбҙҸбҙҚ бҙ„бҙҖбҙҳбҙӣЙӘбҙҸЙҙ"""
    if not caption:
        return []
    import re
    return re.findall(r'#(\w+)', caption)

