#                         бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ sКҸsбҙӣбҙҮбҙҚ КңбҙҖЙҙбҙ…КҹбҙҮКҖs
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

import logging
import uuid
from pyrogram import filters
from pyrogram.types import Message, CallbackQuery

from config import Config
from database import db
from utils.text import to_small_caps
from utils.formatter import format_date
from keyboards.payment import payment_keyboard, payment_confirm_keyboard

logger = logging.getLogger(__name__)

def register(app):
    """КҖбҙҮЙўЙӘsбҙӣбҙҮКҖ бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ КңбҙҖЙҙбҙ…КҹбҙҮКҖs"""
    
    @app.on_message(filters.command("pay") & filters.private)
    async def pay_handler(client, message):
        """ЙӘЙҙЙӘбҙӣЙӘбҙҖбҙӣбҙҮ бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ"""
        user_id = message.from_user.id
        
        # ЙўбҙҮЙҙбҙҮКҖбҙҖбҙӣбҙҮ бҙңЙҙЙӘЗ«бҙңбҙҮ бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ ЙӘбҙ…
        payment_id = f"PAY{user_id}{uuid.uuid4().hex[:8].upper()}"
        
        # бҙ„КҖбҙҮбҙҖбҙӣбҙҮ бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ КҖбҙҮбҙ„бҙҸКҖбҙ…
        await db.create_payment(user_id, payment_id, Config.PAYMENT_AMOUNT)
        
        pay_text = f"""
рҹ’Һ бҙҳКҖбҙҮбҙҚЙӘбҙңбҙҚ бҙңбҙҳЙўКҖбҙҖбҙ…бҙҮ

рҹ’° бҙҖбҙҚбҙҸбҙңЙҙбҙӣ: вӮ№{Config.PAYMENT_AMOUNT}
вҸұпёҸ бҙ…бҙңКҖбҙҖбҙӣЙӘбҙҸЙҙ: {Config.PREMIUM_DAYS} бҙ…бҙҖКҸs
рҹҶ” бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ ЙӘбҙ…: `{payment_id}`

рҹ“ұ sбҙ„бҙҖЙҙ З«КҖ бҙ„бҙҸбҙ…бҙҮ бҙҸКҖ бҙҳбҙҖКҸ бҙ ЙӘбҙҖ бҙңбҙҳЙӘ:
`{Config.UPI_ID}`

вҡ пёҸ ЙӘбҙҚбҙҳбҙҸКҖбҙӣбҙҖЙҙбҙӣ:
1. бҙҳбҙҖКҸ бҙҮxбҙҖбҙ„бҙӣКҹКҸ вӮ№{Config.PAYMENT_AMOUNT}
2. ЙӘЙҙбҙ„Кҹбҙңбҙ…бҙҮ КҸбҙҸбҙңКҖ ЙӘбҙ… ЙӘЙҙ КҖбҙҮбҙҚбҙҖКҖбҙӢs: `{user_id}`
3. бҙ„КҹЙӘбҙ„бҙӢ "вң… ЙӘ'бҙ бҙҮ бҙҳбҙҖЙӘбҙ…" КҷбҙҮКҹбҙҸбҙЎ
4. sбҙҮЙҙбҙ… бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ sбҙ„КҖбҙҮбҙҮЙҙsКңбҙҸбҙӣ

рҹҺҒ КҷбҙҮЙҙбҙҮТ“ЙӘбҙӣs:
вҖў бҙңЙҙКҹЙӘбҙҚЙӘбҙӣбҙҮбҙ… Т“ЙӘКҹбҙҮs
вҖў 2ЙўКҷ бҙңбҙҳКҹбҙҸбҙҖбҙ… КҹЙӘбҙҚЙӘбҙӣ
вҖў бҙҳКҖЙӘбҙҸКҖЙӘбҙӣКҸ sбҙңбҙҳбҙҳбҙҸКҖбҙӣ
вҖў бҙ ЙӘбҙҳ КҷбҙҖбҙ…ЙўбҙҮ
        """
        
        # sбҙҮЙҙбҙ… З«КҖ ЙӘбҙҚбҙҖЙўбҙҮ ЙӘТ“ бҙҖбҙ бҙҖЙӘКҹбҙҖКҷКҹбҙҮ
        try:
            await message.reply_photo(
                photo=Config.UPI_QR_PATH,
                caption=to_small_caps(pay_text),
                reply_markup=payment_confirm_keyboard(payment_id)
            )
        except:
            await message.reply_text(
                to_small_caps(pay_text),
                reply_markup=payment_confirm_keyboard(payment_id)
            )
    
    @app.on_callback_query(filters.regex("^paid_"))
    async def paid_callback(client, callback_query):
        """КңбҙҖЙҙбҙ…КҹбҙҮ бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ бҙ„бҙҸЙҙТ“ЙӘКҖбҙҚбҙҖбҙӣЙӘбҙҸЙҙ"""
        payment_id = callback_query.data.replace("paid_", "")
        
        await callback_query.message.edit_text(
            to_small_caps(f"""
вҸі бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ бҙ бҙҮКҖЙӘТ“ЙӘбҙ„бҙҖбҙӣЙӘбҙҸЙҙ

бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ ЙӘбҙ…: `{payment_id}`

бҙҳКҹбҙҮбҙҖsбҙҮ sбҙҮЙҙбҙ… sбҙ„КҖбҙҮбҙҮЙҙsКңбҙҸбҙӣ бҙҸТ“ КҸбҙҸбҙңКҖ бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ ЙҙбҙҸбҙЎ.
            """)
        )
        
        # sбҙӣбҙҸКҖбҙҮ sбҙӣбҙҖбҙӣбҙҮ Т“бҙҸКҖ ЙҙбҙҮxбҙӣ бҙҚбҙҮssбҙҖЙўбҙҮ
        await db.update_user(callback_query.from_user.id, {
            "pending_payment_id": payment_id
        })
    
    @app.on_message(filters.photo & filters.private)
    async def payment_screenshot_handler(client, message):
        """КңбҙҖЙҙбҙ…КҹбҙҮ бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ sбҙ„КҖбҙҮбҙҮЙҙsКңбҙҸбҙӣ"""
        user_id = message.from_user.id
        user = await db.get_user(user_id)
        
        if not user or not user.get("pending_payment_id"):
            return  # ЙҙбҙҸбҙӣ бҙҖ бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ sбҙ„КҖбҙҮбҙҮЙҙsКңбҙҸбҙӣ
        
        payment_id = user["pending_payment_id"]
        
        # Т“бҙҸКҖбҙЎбҙҖКҖбҙ… бҙӣбҙҸ бҙҸбҙЎЙҙбҙҮКҖ Т“бҙҸКҖ бҙ бҙҮКҖЙӘТ“ЙӘбҙ„бҙҖбҙӣЙӘбҙҸЙҙ
        try:
            await message.forward(Config.OWNER_ID)
            
            # sбҙҮЙҙбҙ… бҙ бҙҮКҖЙӘТ“ЙӘбҙ„бҙҖбҙӣЙӘбҙҸЙҙ КҖбҙҮЗ«бҙңбҙҮsбҙӣ бҙӣбҙҸ бҙҸбҙЎЙҙбҙҮКҖ
            await client.send_message(
                Config.OWNER_ID,
                f"рҹ’° ЙҙбҙҮбҙЎ бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ Т“бҙҸКҖ бҙ бҙҮКҖЙӘТ“ЙӘбҙ„бҙҖбҙӣЙӘбҙҸЙҙ\n\n"
                f"бҙңsбҙҮКҖ: {message.from_user.mention}\n"
                f"ЙӘбҙ…: `{user_id}`\n"
                f"бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ ЙӘбҙ…: `{payment_id}`",
                reply_markup=InlineKeyboardMarkup([
                    [
                        InlineKeyboardButton("вң… бҙҖбҙҳбҙҳКҖбҙҸбҙ бҙҮ", callback_data=f"approve_pay_{user_id}_{payment_id}"),
                        InlineKeyboardButton("вқҢ КҖбҙҮбҙҠбҙҮбҙ„бҙӣ", callback_data=f"reject_pay_{user_id}_{payment_id}")
                    ]
                ])
            )
            
            await message.reply_text(
                to_small_caps("вң… sбҙ„КҖбҙҮбҙҮЙҙsКңбҙҸбҙӣ КҖбҙҮбҙ„бҙҮЙӘбҙ бҙҮбҙ…! бҙЎбҙҖЙӘбҙӣЙӘЙҙЙў Т“бҙҸКҖ бҙ бҙҮКҖЙӘТ“ЙӘбҙ„бҙҖбҙӣЙӘбҙҸЙҙ.")
            )
            
            # бҙ„КҹбҙҮбҙҖКҖ бҙҳбҙҮЙҙбҙ…ЙӘЙҙЙў sбҙӣбҙҖбҙӣбҙҮ
            await db.update_user(user_id, {"$unset": {"pending_payment_id": ""}})
            
        except Exception as e:
            logger.error(f"Т“бҙҖЙӘКҹбҙҮбҙ… бҙӣбҙҸ Т“бҙҸКҖбҙЎбҙҖКҖбҙ… бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ: {e}")
