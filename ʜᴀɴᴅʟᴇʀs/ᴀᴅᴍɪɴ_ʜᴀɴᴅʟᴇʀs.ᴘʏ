import logging
from pyrogram import filters
from pyrogram.types import Message

from config import Config
from database import db
from utils.text import to_small_caps
from keyboards.admin import admin_keyboard

logger = logging.getLogger(__name__)

def is_admin(user_id):
    """бҙ„КңбҙҮбҙ„бҙӢ ЙӘТ“ бҙңsбҙҮКҖ ЙӘs бҙҖбҙ…бҙҚЙӘЙҙ"""
    return user_id == Config.OWNER_ID or user_id in Config.ADMIN_IDS

def register(app):
    """КҖбҙҮЙўЙӘsбҙӣбҙҮКҖ бҙҖбҙ…бҙҚЙӘЙҙ КңбҙҖЙҙбҙ…КҹбҙҮКҖs"""
    
    @app.on_message(filters.command("admin") & filters.private)
    async def admin_panel(client, message):
        """бҙҖбҙ…бҙҚЙӘЙҙ бҙҳбҙҖЙҙбҙҮКҹ"""
        if not is_admin(message.from_user.id):
            return
        
        stats = await db.get_stats()
        
        admin_text = f"""
рҹ”җ бҙҖбҙ…бҙҚЙӘЙҙ бҙҳбҙҖЙҙбҙҮКҹ

рҹ“Ҡ sбҙӣбҙҖбҙӣЙӘsбҙӣЙӘбҙ„s:
вҖў бҙңsбҙҮКҖs: {stats['total_users']} (+{stats['today_users']} бҙӣбҙҸбҙ…бҙҖКҸ)
вҖў Т“ЙӘКҹбҙҮs: {stats['total_files']} ({stats['today_uploads']} бҙӣбҙҸбҙ…бҙҖКҸ)
вҖў бҙҳКҖбҙҮбҙҚЙӘбҙңбҙҚ: {stats['premium_users']}
вҖў бҙҳбҙҮЙҙбҙ…ЙӘЙҙЙў бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣs: {stats['pending_payments']}
вҖў бҙҖбҙ„бҙӣЙӘбҙ бҙҮ бҙӣбҙҸбҙ…бҙҖКҸ: {stats['active_today']}

sбҙҮКҹбҙҮбҙ„бҙӣ бҙҖЙҙ бҙҸбҙҳбҙӣЙӘбҙҸЙҙ КҷбҙҮКҹбҙҸбҙЎ:
        """
        
        await message.reply_text(
            to_small_caps(admin_text),
            reply_markup=admin_keyboard()
        )
    
    @app.on_callback_query(filters.regex("^approve_pay_"))
    async def approve_payment(client, callback_query):
        """бҙҖбҙҳбҙҳКҖбҙҸбҙ бҙҮ бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ"""
        if not is_admin(callback_query.from_user.id):
            return
        
        data = callback_query.data.replace("approve_pay_", "").split("_")
        user_id = int(data[0])
        payment_id = data[1]
        
        success = await db.verify_payment(payment_id, callback_query.from_user.id)
        
        if success:
            # ЙҙбҙҸбҙӣЙӘТ“КҸ бҙңsбҙҮКҖ
            try:
                await client.send_message(
                    user_id,
                    to_small_caps(f"""
рҹҺү бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ бҙҖбҙҳбҙҳКҖбҙҸбҙ бҙҮбҙ…!

рҹ’Һ бҙҳКҖбҙҮбҙҚЙӘбҙңбҙҚ бҙҖбҙ„бҙӣЙӘбҙ бҙҖбҙӣбҙҮбҙ… Т“бҙҸКҖ {Config.PREMIUM_DAYS} бҙ…бҙҖКҸs

бҙҮЙҙбҙҠбҙҸКҸ бҙңЙҙКҹЙӘбҙҚЙӘбҙӣбҙҮбҙ… Т“бҙҮбҙҖбҙӣбҙңКҖбҙҮs!
                    """)
                )
            except:
                pass
            
            await callback_query.message.edit_text(
                to_small_caps(f"вң… бҙҳбҙҖКҸбҙҚбҙҮЙҙбҙӣ {payment_id} бҙҖбҙҳбҙҳКҖбҙҸбҙ бҙҮбҙ…")
            )
        else:
            await callback_query.answer("Т“бҙҖЙӘКҹбҙҮбҙ… бҙӣбҙҸ бҙҖбҙҳбҙҳКҖбҙҸбҙ бҙҮ", show_alert=True)
    
    @app.on_message(filters.command("broadcast") & filters.private)
    async def broadcast_handler(client, message):
        """КҷКҖбҙҸбҙҖбҙ…бҙ„бҙҖsбҙӣ бҙҚбҙҮssбҙҖЙўбҙҮ"""
        if not is_admin(message.from_user.id):
            return
        
        if len(message.command) < 2:
            await message.reply_text("бҙңsбҙҖЙўбҙҮ: /broadcast <бҙҚбҙҮssбҙҖЙўбҙҮ>")
            return
        
        broadcast_text = " ".join(message.command[1:])
        
        # ЙўбҙҮбҙӣ бҙҖКҹКҹ бҙңsбҙҮКҖs
        users = await db.get_all_users()
        
        status = await message.reply_text(f"КҷКҖбҙҸбҙҖбҙ…бҙ„бҙҖsбҙӣЙӘЙҙЙў бҙӣбҙҸ {len(users)} бҙңsбҙҮКҖs...")
        
