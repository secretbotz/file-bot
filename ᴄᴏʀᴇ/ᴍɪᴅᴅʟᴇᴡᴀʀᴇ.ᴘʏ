import logging
from pyrogram.enums import ChatMemberStatus
from pyrogram.errors import UserNotParticipant

from config import Config
from database import db

logger = logging.getLogger(__name__)

class Middleware:
    """ᴍᴇssᴀɢᴇ ᴍɪᴅᴅʟᴇᴡᴀʀᴇ"""
    
    async def process(self, client, message):
        """ᴘʀᴏᴄᴇss ɪɴᴄᴏᴍɪɴɢ ᴍᴇssᴀɢᴇ"""
        # ᴜᴘᴅᴀᴛᴇ ʟᴀsᴛ ᴀᴄᴛɪᴠᴇ
        if message.from_user:
            await db.update_user(message.from_user.id, {})

async def require_subscription(client, user_id):
    """ᴄʜᴇᴄᴋ ɪғ ᴜsᴇʀ ɪs sᴜʙsᴄʀɪʙᴇᴅ ᴛᴏ ғᴏʀᴄᴇ ᴄʜᴀɴɴᴇʟ"""
    if not Config.FORCE_SUB_CHANNEL:
        return True
    
    try:
        member = await client.get_chat_member(
            Config.FORCE_SUB_CHANNEL, 
            user_id
        )
        return member.status in [ChatMemberStatus.MEMBER, 
                                  ChatMemberStatus.ADMINISTRATOR, 
                                  ChatMemberStatus.OWNER]
    except UserNotParticipant:
        return False
    except Exception as e:
        logger.error(f"sᴜʙsᴄʀɪᴘᴛɪᴏɴ ᴄʜᴇᴄᴋ ᴇʀʀᴏʀ: {e}")
        return True
