#                         ᴛᴇxᴛ ᴘʀᴏᴄᴇssɪɴɢ (sᴍᴀʟʟ ᴄᴀᴘs)
# ═══════════════════════════════════════════════════════════════════════════════

import re

# sᴍᴀʟʟ ᴄᴀᴘs ᴍᴀᴘᴘɪɴɢ
SMALL_CAPS = {
    'a': 'ᴀ', 'b': 'ʙ', 'c': 'ᴄ', 'd': 'ᴅ', 'e': 'ᴇ', 'f': 'ғ', 'g': 'ɢ',
    'h': 'ʜ', 'i': 'ɪ', 'j': 'ᴊ', 'k': 'ᴋ', 'l': 'ʟ', 'm': 'ᴍ', 'n': 'ɴ',
    'o': 'ᴏ', 'p': 'ᴘ', 'q': 'ǫ', 'r': 'ʀ', 's': 's', 't': 'ᴛ', 'u': 'ᴜ',
    'v': 'ᴠ', 'w': 'ᴡ', 'x': 'x', 'y': 'ʏ', 'z': 'ᴢ',
    'A': 'ᴀ', 'B': 'ʙ', 'C': 'ᴄ', 'D': 'ᴅ', 'E': 'ᴇ', 'F': 'ғ', 'G': 'ɢ',
    'H': 'ʜ', 'I': 'ɪ', 'J': 'ᴊ', 'K': 'ᴋ', 'L': 'ʟ', 'M': 'ᴍ', 'N': 'ɴ',
    'O': 'ᴏ', 'P': 'ᴘ', 'Q': 'ǫ', 'R': 'ʀ', 'S': 's', 'T': 'ᴛ', 'U': 'ᴜ',
    'V': 'ᴠ', 'W': 'ᴡ', 'X': 'x', 'Y': 'ʏ', 'Z': 'ᴢ'
}

# ᴘʀᴏᴛᴇᴄᴛᴇᴅ ᴘᴀᴛᴛᴇʀɴs (ᴅᴏɴ'ᴛ ᴄᴏɴᴠᴇʀᴛ ᴛʜᴇsᴇ)
PROTECTED = [
    r'/\w+',  # ᴄᴏᴍᴍᴀɴᴅs
    r'@\w+',  # ᴜsᴇʀɴᴀᴍᴇs
    r't\.me/\w+',  # ʟɪɴᴋs
    r'\d+',  # ɴᴜᴍʙᴇʀs
    r'<[^>]+>',  # ʜᴛᴍʟ ᴛᴀɢs
    r'https?://\S+',  # ᴜʀʟs
    r'`[^`]+`',  # ɪɴʟɪɴᴇ ᴄᴏᴅᴇ
    r'\[([^\]]+)\]\(([^)]+)\)'  # ᴍᴀʀᴋᴅᴏᴡɴ ʟɪɴᴋs
]

def to_small_caps(text: str) -> str:
    """
    ᴄᴏɴᴠᴇʀᴛ ᴛᴇxᴛ ᴛᴏ sᴍᴀʟʟ ᴄᴀᴘs ᴡʜɪʟᴇ ᴘʀᴏᴛᴇᴄᴛɪɴɢ sᴘᴇᴄɪᴀʟ ᴄᴏɴᴛᴇɴᴛ
    """
    if not text:
        return text
    
    # ᴄᴏᴍʙɪɴᴇ ᴘʀᴏᴛᴇᴄᴛᴇᴅ ᴘᴀᴛᴛᴇʀɴs
    pattern = '|'.join(f'({p})' for p in PROTECTED)
    
    # sᴘʟɪᴛ ʙʏ ᴘʀᴏᴛᴇᴄᴛᴇᴅ ᴘᴀᴛᴛᴇʀɴs
    parts = re.split(f'({pattern})', text)
    
    result = []
    for part in parts:
        if not part:
            continue
        
        # ᴄʜᴇᴄᴋ ɪғ ᴘʀᴏᴛᴇᴄᴛᴇᴅ
        is_protected = any(re.fullmatch(p, part) for p in PROTECTED)
        
        if is_protected:
            result.append(part)
        else:
            # ᴄᴏɴᴠᴇʀᴛ ᴛᴏ sᴍᴀʟʟ ᴄᴀᴘs
            converted = ''.join(SMALL_CAPS.get(c, c) for c in part)
            result.append(converted)
    
    return ''.join(result)
